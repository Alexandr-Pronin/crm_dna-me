# =============================================================================
# DNA ME CRM — AWS Environment (copy to .env.aws and fill values)
# =============================================================================

# Domain & SSL
DOMAIN_NAME=crm.dna-me.com
LETSENCRYPT_EMAIL=admin@dna-me.com

# Database (2-instance: deploy-aws.sh sets DATABASE_URL from DbPrivateIP)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# DATABASE_URL is auto-generated: postgres://dna:PASSWORD@<DB_PRIVATE_IP>:5432/dna_marketing

# Redis (container-internal)
REDIS_URL=redis://redis:6379

# CORS (optional, defaults to https://${DOMAIN_NAME})
CORS_ORIGIN=https://crm.dna-me.net

# Security
JWT_SECRET=CHANGE_ME_64_CHARS
WEBHOOK_SECRET=CHANGE_ME_32_CHARS
API_KEYS=prod_key:manual

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASS=your_password
SMTP_SECURE=false
SMTP_FROM=info@dna-me.com
SMTP_FROM_NAME=DNA ME

# Optional integrations
MOCO_API_KEY=
MOCO_SUBDOMAIN=
# Slack
# SLACK_WEBHOOK_URL=
# SLACK_BOT_TOKEN=
# ENABLE_SLACK_ALERTS=true

# LinkedIn Integration
# Standard OAuth (profile read only, NO messaging)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=https://crm.dna-me.com/api/v1/linkedin/callback
# SNAP (Sales Navigator API) – requires LinkedIn partner agreement
# LINKEDIN_SNAP_PARTNER_ID=
# Third-party gateway (e.g. Unipile ~$99/mo) for messaging
# LINKEDIN_GATEWAY_URL=
# LINKEDIN_GATEWAY_API_KEY=
# ENABLE_LINKEDIN=true

# Optional: S3 bucket for backups
# S3_BUCKET=your-bucket-name
